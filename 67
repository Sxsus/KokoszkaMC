<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KokoszkaMC v4.5 Compact | Wersje 1.21.x</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800;900&family=Montserrat:wght@800;900&display=swap" rel="stylesheet">
    <style>
        /* =========================================================
           STYLIZACJA (NEOBRUTALIZM - BIAŁY, CZARNY, POMARAŃCZOWY)
           ========================================================= */
        :root {
            --primary: #ff8c00;
            --bg: #f8fafc;
            --surface: #ffffff;
            --text: #000000;
            --border: 4px solid #000000;
            --shadow: 6px 6px 0px 0px #000000;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; outline: none; }
        body { background-color: var(--bg); color: var(--text); height: 100vh; overflow: hidden; display: flex; }

        /* --- EKRAN LOGOWANIA I REJESTRACJI --- */
        #auth-screen {
            position: fixed; inset: 0; background-color: var(--bg);
            background-image: radial-gradient(#cbd5e1 2px, transparent 2px); background-size: 30px 30px;
            display: flex; align-items: center; justify-content: center; z-index: 1000;
        }
        .auth-box {
            width: 100%; max-width: 500px; background: var(--surface);
            border: var(--border); box-shadow: var(--shadow); padding: 40px;
            display: flex; flex-direction: column; gap: 20px;
        }
        .auth-header { text-align: center; margin-bottom: 10px; }
        .auth-header h1 { font-family: 'Montserrat', sans-serif; font-size: 36px; font-weight: 900; text-transform: uppercase; }
        
        .auth-tabs { display: flex; border: var(--border); border-bottom: none; background: #e2e8f0; }
        .tab-btn {
            flex: 1; padding: 15px; font-size: 16px; font-weight: 800; text-align: center;
            cursor: pointer; border: none; background: transparent; transition: 0.2s;
        }
        .tab-btn.active { background: var(--primary); color: white; border-bottom: 4px solid var(--primary); }
        .tab-btn:not(.active):hover { background: #cbd5e1; }

        .auth-inputs { border: var(--border); padding: 30px; display: flex; flex-direction: column; gap: 20px; margin-top: -4px; background: var(--surface); }
        .input-field { width: 100%; padding: 15px; font-size: 16px; font-weight: 600; border: var(--border); }
        .input-field:focus { box-shadow: 4px 4px 0px var(--primary); transform: translate(-2px, -2px); }
        
        .auth-submit {
            width: 100%; padding: 20px; font-size: 20px; font-weight: 900; text-transform: uppercase;
            background: var(--surface); border: var(--border); cursor: pointer; transition: 0.2s;
        }
        .auth-submit:hover { background: var(--primary); box-shadow: var(--shadow); transform: translate(-4px, -4px); }
        .auth-submit:active { box-shadow: none; transform: translate(0,0); }
        .error-msg { color: #ef4444; font-weight: 800; text-align: center; min-height: 20px; }

        /* --- GŁÓWNA APLIKACJA --- */
        #app-screen { display: none; width: 100vw; height: 100vh; }
        
        .sidebar { width: 300px; background: var(--surface); border-right: var(--border); display: flex; flex-direction: column; }
        .brand { padding: 30px; border-bottom: var(--border); background: var(--primary); }
        .brand h2 { font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 900; line-height: 1; }
        .menu { padding: 20px; flex-grow: 1; }
        .menu-item { padding: 15px; font-size: 15px; font-weight: 800; cursor: pointer; border: 2px solid transparent; margin-bottom: 5px; transition: 0.2s; }
        .menu-item:hover { border-color: var(--text); transform: translate(-2px, -2px); box-shadow: 4px 4px 0px var(--text); }
        .menu-item.active { background: var(--text); color: white; border-color: var(--text); }
        
        .main-content { flex-grow: 1; display: flex; flex-direction: column; background: var(--bg); }
        .topbar { height: 80px; background: var(--surface); border-bottom: var(--border); padding: 0 40px; display: flex; align-items: center; justify-content: space-between; }
        .topbar h3 { font-size: 20px; font-weight: 900; text-transform: uppercase; }
        .user-badge { font-weight: 800; border: var(--border); padding: 8px 20px; background: var(--primary); color: white; box-shadow: 4px 4px 0px black; }

        .canvas { padding: 40px; overflow-y: auto; flex-grow: 1; }
        .view { display: none; }
        .view.active { display: block; animation: slideIn 0.3s ease; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        /* --- KARTY I ELEMENTY --- */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 30px; margin-bottom: 30px; }
        .card { background: var(--surface); border: var(--border); padding: 30px; box-shadow: var(--shadow); transition: 0.2s; }
        .card:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0px black; }
        .card h3 { font-size: 22px; font-weight: 900; margin-bottom: 15px; text-transform: uppercase; }
        
        .btn { padding: 15px 30px; font-size: 16px; font-weight: 900; background: var(--surface); border: var(--border); cursor: pointer; text-transform: uppercase; transition: 0.2s; }
        .btn:hover { background: var(--primary); box-shadow: 4px 4px 0px black; transform: translate(-2px, -2px); }
        .btn.btn-green { background: #10b981; color: white; }
        .btn.btn-red { background: #ef4444; color: white; }

        select.huge-select { width: 100%; padding: 15px; font-size: 20px; font-weight: 800; border: var(--border); margin-bottom: 20px; cursor: pointer; }
        select.huge-select:focus { box-shadow: 4px 4px 0px var(--primary); transform: translate(-2px, -2px); }

        #toast { position: fixed; bottom: 30px; right: 30px; background: var(--text); color: white; padding: 20px 30px; font-weight: 800; border: var(--border); transform: translateY(150%); transition: 0.4s; z-index: 9999; }
        #toast.show { transform: translateY(0); }
    </style>
</head>
<body>

    <div id="auth-screen">
        <div class="auth-box">
            <div class="auth-header">
                <h1>KokoszkaMC</h1>
                <p style="font-weight: 600;">Panel Zarządzania Węzłem</p>
            </div>
            
            <div class="auth-tabs">
                <button id="tab-reg" class="tab-btn" onclick="app.switchTab('reg')">Rejestracja</button>
                <button id="tab-log" class="tab-btn active" onclick="app.switchTab('log')">Logowanie</button>
            </div>

            <div class="auth-inputs">
                <div>
                    <label style="font-weight: 800; font-size: 12px; text-transform: uppercase;">Nazwa Użytkownika</label>
                    <input type="text" id="auth-user" class="input-field" placeholder="Wpisz nick">
                </div>
                <div>
                    <label style="font-weight: 800; font-size: 12px; text-transform: uppercase;">Hasło</label>
                    <input type="password" id="auth-pass" class="input-field" placeholder="••••••••">
                </div>
                <div id="auth-err" class="error-msg"></div>
            </div>

            <button id="auth-btn" class="auth-submit" onclick="app.submitAuth()">ZALOGUJ SIĘ</button>
        </div>
    </div>

    <div id="app-screen">
        <div class="sidebar">
            <div class="brand">
                <h2>KOKOSZKA</h2>
                <span style="font-weight: 900; font-size: 12px;">TITAN v4.5</span>
            </div>
            <div class="menu">
                <div class="menu-item active" onclick="app.switchView('dash', this)">Pulpit Sterowania</div>
                <div class="menu-item" onclick="app.switchView('soft', this)">Silnik i Wersja 1.21</div>
                <div class="menu-item" onclick="location.reload()" style="margin-top: 50px; color: #ef4444; border-color: #ef4444;">Wyloguj</div>
            </div>
        </div>

        <div class="main-content">
            <div class="topbar">
                <h3 id="topbar-title">Pulpit Sterowania</h3>
                <div class="user-badge" id="display-user">Gość</div>
            </div>

            <div class="canvas">
                
                <div id="view-dash" class="view active">
                    <div class="grid">
                        <div class="card">
                            <h3>Status Serwera</h3>
                            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 20px;">
                                <div id="status-orb" style="width: 50px; height: 50px; border-radius: 50%; border: var(--border); background: #ef4444;"></div>
                                <div>
                                    <h2 id="status-txt" style="font-size: 32px; font-weight: 900;">OFFLINE</h2>
                                    <span id="status-ip" style="font-weight: 700; color: var(--primary);">Brak Maszyny</span>
                                </div>
                            </div>
                            <div style="display: flex; gap: 10px;">
                                <button id="btn-power" class="btn btn-green" style="flex: 2;" onclick="server.togglePower()">START</button>
                                <button class="btn btn-red" style="flex: 1;" onclick="server.kill()">KILL</button>
                            </div>
                        </div>

                        <div class="card">
                            <h3>Informacje o Węźle</h3>
                            <div style="margin-bottom: 15px;">
                                <div style="font-weight: 800; font-size: 14px; text-transform: uppercase;">Zainstalowana Wersja MC:</div>
                                <div id="info-version" style="font-size: 24px; font-weight: 900; color: var(--primary);">Brak</div>
                            </div>
                            <div>
                                <div style="font-weight: 800; font-size: 14px; text-transform: uppercase;">Zainstalowany Silnik:</div>
                                <div id="info-engine" style="font-size: 24px; font-weight: 900;">Brak</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="view-soft" class="view">
                    <div class="card" style="max-width: 800px;">
                        <h3>Instalator Oprogramowania</h3>
                        <p style="font-weight: 600; margin-bottom: 20px;">Wybierz silnik i jedną z najnowszych wersji Minecrafta. Wersja 1.21.4 jest zalecana.</p>
                        
                        <label style="font-weight: 800; font-size: 14px; text-transform: uppercase;">Wybierz Silnik:</label>
                        <select id="sel-engine" class="huge-select">
                            <option value="PaperMC" selected>PaperMC (Wydajność)</option>
                            <option value="Vanilla">Vanilla (Czysty)</option>
                            <option value="Forge">Forge (Mody)</option>
                        </select>

                        <label style="font-weight: 800; font-size: 14px; text-transform: uppercase;">Wybierz Wersję Gry:</label>
                        <select id="sel-version" class="huge-select">
                            </select>

                        <button class="btn btn-green" style="width: 100%; font-size: 20px;" onclick="server.installSoftware()">ZAINSTALUJ WERSJĘ</button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div id="toast">Wiadomość z systemu</div>

    <script>
        // 1. Zdefiniowanie wersji od 1.21.11 do 1.21.1 (plus starsze)
        const MC_VERSIONS = [
            "1.21.11", "1.21.10", "1.21.9", "1.21.8", "1.21.7", "1.21.6", "1.21.5", 
            "1.21.4", "1.21.3", "1.21.2", "1.21.1", "1.21", "1.20.4", "1.19.4", "1.16.5"
        ];

        const app = {
            mode: 'log',
            db: JSON.parse(localStorage.getItem('kokoszka_db_v45') || "{}"),
            user: null,

            init() {
                // Wypełnianie listy wyboru wersji w HTML
                const selectVer = document.getElementById('sel-version');
                MC_VERSIONS.forEach(v => {
                    let opt = document.createElement('option');
                    opt.value = v;
                    opt.innerText = v;
                    // Domyślnie podświetlamy i wybieramy wersję 1.21.4
                    if (v === "1.21.4") opt.selected = true; 
                    selectVer.appendChild(opt);
                });
                this.switchTab('log');
            },

            switchTab(m) {
                this.mode = m;
                document.getElementById('auth-err').innerText = "";
                document.getElementById('auth-user').value = "";
                document.getElementById('auth-pass').value = "";

                if(m === 'log') {
                    document.getElementById('tab-log').classList.add('active');
                    document.getElementById('tab-reg').classList.remove('active');
                    document.getElementById('auth-btn').innerText = "ZALOGUJ SIĘ";
                } else {
                    document.getElementById('tab-reg').classList.add('active');
                    document.getElementById('tab-log').classList.remove('active');
                    document.getElementById('auth-btn').innerText = "STWÓRZ KONTO";
                }
            },

            submitAuth() {
                const u = document.getElementById('auth-user').value.trim();
                const p = document.getElementById('auth-pass').value.trim();
                const err = document.getElementById('auth-err');

                if(u.length < 3) return err.innerText = "NICK ZA KRÓTKI!";
                if(p.length < 4) return err.innerText = "HASŁO ZA KRÓTKIE!";

                if(this.mode === 'reg') {
                    if(this.db[u]) return err.innerText = "KONTO ISTNIEJE!";
                    // Tworzymy konto i od razu "wirtualny" serwer z domyślną wersją 1.21.4
                    this.db[u] = { pass: p, engine: "PaperMC", version: "1.21.4" };
                    localStorage.setItem('kokoszka_db_v45', JSON.stringify(this.db));
                    alert("Zarejestrowano! Przełączam do logowania.");
                    this.switchTab('log');
                } else {
                    if(!this.db[u] || this.db[u].pass !== p) return err.innerText = "BŁĘDNE DANE!";
                    this.user = u;
                    this.loginSuccess();
                }
            },

            loginSuccess() {
                document.getElementById('auth-screen').style.display = 'none';
                document.getElementById('app-screen').style.display = 'flex';
                document.getElementById('display-user').innerText = this.user;
                server.loadData();
            },

            switchView(id, el) {
                document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
                document.querySelectorAll('.menu-item').forEach(i => i.classList.remove('active'));
                document.getElementById('view-' + id).classList.add('active');
                el.classList.add('active');
                document.getElementById('topbar-title').innerText = el.innerText;
            },

            toast(msg) {
                const t = document.getElementById('toast');
                t.innerText = msg;
                t.classList.add('show');
                setTimeout(() => t.classList.remove('show'), 3000);
            }
        };

        const server = {
            online: false,

            loadData() {
                const data = app.db[app.user];
                // Wczytanie danych z bazy do panelu Dashboard
                document.getElementById('status-ip').innerText = app.user.toLowerCase() + ".kokoszka.me";
                document.getElementById('info-engine').innerText = data.engine;
                document.getElementById('info-version').innerText = data.version;
            },

            installSoftware() {
                const eng = document.getElementById('sel-engine').value;
                const ver = document.getElementById('sel-version').value;
                
                // Zapisujemy nową wersję do bazy danych LocalStorage
                app.db[app.user].engine = eng;
                app.db[app.user].version = ver;
                localStorage.setItem('kokoszka_db_v45', JSON.stringify(app.db));
                
                // Odświeżamy widok na pulpicie, żeby pokazać że to "działa"
                this.loadData();
                app.toast(`Pomyślnie zainstalowano: ${eng} wersja ${ver}`);
            },

            togglePower() {
                const btn = document.getElementById('btn-power');
                const orb = document.getElementById('status-orb');
                const txt = document.getElementById('status-txt');

                if(!this.online) {
                    this.online = true;
                    btn.innerText = "ZATRZYMAJ"; btn.className = "btn btn-red";
                    orb.style.background = "#10b981"; txt.innerText = "ONLINE";
                    app.toast("Serwer uruchomiony!");
                } else {
                    this.online = false;
                    btn.innerText = "START"; btn.className = "btn btn-green";
                    orb.style.background = "#ef4444"; txt.innerText = "OFFLINE";
                    app.toast("Serwer zatrzymany.");
                }
            },

            kill() {
                if(this.online) this.togglePower();
                app.toast("Zabito proces serwera!");
            }
        };

        window.onload = () => app.init();
    </script>
</body>
</html>
